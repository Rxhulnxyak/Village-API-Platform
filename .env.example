# NeonDB pooled connection string (from neon.tech dashboard)
DATABASE_URL=
# NeonDB direct connection (bypasses pgBouncer, needed for migrations)
DIRECT_URL=
# Upstash Redis URL (from upstash.com console)
REDIS_URL=
# Upstash Redis token
REDIS_TOKEN=
# Min 64 random chars — generate: openssl rand -hex 32
JWT_SECRET=
# 7 days for B2B users (long sessions reduce friction for automated scripts)
JWT_EXPIRES_IN=7d
# Super admin login email
ADMIN_EMAIL=
# bcrypt hash of admin password — generate with scripts/hashPassword.ts
ADMIN_PASSWORD_HASH=
# Email provider SMTP host (e.g. smtp.sendgrid.net)
SMTP_HOST=
# TLS port
SMTP_PORT=587
# SMTP username
SMTP_USER=
# SMTP password or API key
SMTP_PASS=
# "VillageAPI <noreply@villageapi.com>"
SMTP_FROM=
# https://admin.villageapi.com (for email deep links)
FRONTEND_ADMIN_URL=
# https://app.villageapi.com
FRONTEND_B2B_URL=
# https://demo.villageapi.com
DEMO_URL=
NODE_ENV=development
PORT=3000
# http://localhost:3000 in dev, https://api.villageapi.com in prod
VITE_API_URL=
